# Copy this file to .env and fill in your values
# cp .env.example .env

# ── SMTP Settings ──────────────────────────────────────────
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=hello@wattprotocol.io
#   SMTP_PASS=your-app-password   ← Gmail: use an App Password, not your login password
#                                   https://myaccount.google.com/apppasswords
#
# Other providers: just swap host/port
#   Outlook/Hotmail: smtp-mail.outlook.com / 587
#   Zoho:            smtp.zoho.com         / 587
#   Custom SMTP:     your mail server      / 587 or 465

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dawendoski@gmail.com
SMTP_PASS=jkljwgnjjyfnateb

# ── Sender & site ──────────────────────────────────────────
FROM_EMAIL=hello@wattprotocol.io
FROM_NAME=$WATT Protocol
SITE_URL=https://wattprotocol.io

# ── Supabase ───────────────────────────────────────────────
# supabase.com → New project → Settings → API
# Use the SERVICE ROLE key (not anon) — this stays on the server only
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Server ─────────────────────────────────────────────────
PORT=3001
